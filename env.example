# ============================================
# SudanMed — Environment Variables Template
# انسخ هذا الملف إلى .env وأضف القيم الحقيقية
# لا ترفع .env إلى GitHub أبداً
# ============================================

# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/sudanmed"

# Redis (Upstash)
REDIS_URL="redis://default:password@host:6379"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary (صور)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Twilio (OTP/SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# SendGrid (Email)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@sudanmed.com"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Algolia (Search)
ALGOLIA_APP_ID=""
ALGOLIA_API_KEY=""
ALGOLIA_SEARCH_KEY=""

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# Bankak (يدوي)
BANKAK_MERCHANT_ACCOUNT="+249xxxxxxxxx"

# App
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"
